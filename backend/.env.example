# 年假查询系统 v1.5 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============================================
# 飞书应用配置（必填）
# ============================================
# 飞书开放平台 - 应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格 Token
# 在飞书多维表格页面 URL 中获取：https://www.feishu.cn/base/{APP_TOKEN}?table=xxxxx
FEISHU_APP_TOKEN=xxxxxxxxxxxxxxxxxxxx

# 加密密钥（用于事件订阅验证，可选）
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# ============================================
# 多维表格配置（必填）
# ============================================
# 员工信息表 ID（从飞书多维表格 URL 中获取 table= 后面的值）
EMPLOYEE_TABLE_ID=tblxxxxxxxxxxxxxx

# 请假记录表 ID
LEAVE_TABLE_ID=tblxxxxxxxxxxxxxx

# ============================================
# JWT 安全配置（必填，生产环境请修改）
# ============================================
# JWT 签名密钥（生产环境请使用强随机字符串）
# 未配置时服务将拒绝启动
JWT_SECRET_KEY=your-strong-secret-key-change-in-production

# Token 过期时间（分钟，默认 8 小时）
JWT_EXPIRE_MINUTES=480

# ============================================
# HR 权限配置（必填）
# ============================================
# HR 用户的飞书 Open ID，逗号分隔
# 如何获取：用户登录后，后端日志会打印 open_id，或从飞书管理后台获取
HR_USERS=ou_xxxxxxxxxxxxxxxx,ou_yyyyyyyyyyyyyyyy

# ============================================
# 缓存配置（v1.5 新增）
# ============================================
# 缓存类型：memory 或 redis
# memory: 内存缓存（单机部署）
# redis: Redis 缓存（多实例部署，推荐生产环境）
CACHE_TYPE=memory

# Redis URL（当 CACHE_TYPE=redis 时必填）
# REDIS_URL=redis://localhost:6379/0

# ============================================
# 数据库配置（v1.5 新增）
# ============================================
# 数据库类型：sqlite 或 postgres
# sqlite: SQLite 文件数据库（小团队，开发和测试）
# postgres: PostgreSQL（500人规模，生产环境推荐）
DB_TYPE=sqlite

# PostgreSQL URL（当 DB_TYPE=postgres 时必填）
# DATABASE_URL=postgresql://user:password@localhost:5432/annual_leave

# SQLite 数据库路径（当 DB_TYPE=sqlite 时使用）
DB_PATH=data/leave_adjustments.db

# ============================================
# CORS 配置（可选，默认限制为飞书域名）
# ============================================
# 生产环境建议限制为飞书域名
# 默认已限制为飞书域名，如需开发调试可设置为 *
# CORS_ORIGINS=*

# ============================================
# 其他配置（可选）
# ============================================
# 时区设置
TIMEZONE=Asia/Shanghai
