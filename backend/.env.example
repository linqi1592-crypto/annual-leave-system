# 年假查询系统 v1.3 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============================================
# 飞书应用配置（必填）
# ============================================
# 飞书开放平台 - 应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格 Token
# 在飞书多维表格页面 URL 中获取：https://www.feishu.cn/base/{APP_TOKEN}?table=xxxxx
FEISHU_APP_TOKEN=xxxxxxxxxxxxxxxxxxxx

# 加密密钥（用于事件订阅验证，可选）
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# ============================================
# 多维表格配置（必填）
# ============================================
# 员工信息表 ID（从飞书多维表格 URL 中获取 table= 后面的值）
EMPLOYEE_TABLE_ID=tblxxxxxxxxxxxxxx

# 请假记录表 ID
LEAVE_TABLE_ID=tblxxxxxxxxxxxxxx

# ============================================
# JWT 安全配置（必填，生产环境请修改）
# ============================================
# JWT 签名密钥（生产环境请使用强随机字符串）
JWT_SECRET_KEY=your-strong-secret-key-change-in-production

# Token 过期时间（分钟，默认 8 小时）
JWT_EXPIRE_MINUTES=480

# ============================================
# HR 权限配置（必填）
# ============================================
# HR 用户的飞书 Open ID，逗号分隔
# 如何获取：用户登录后，后端日志会打印 open_id，或从飞书管理后台获取
HR_USERS=ou_xxxxxxxxxxxxxxxx,ou_yyyyyyyyyyyyyyyy

# ============================================
# CORS 配置（可选，默认允许所有）
# ============================================
# 生产环境建议限制为飞书域名
# CORS_ORIGINS=https://www.feishu.cn,https://open.feishu.cn
CORS_ORIGINS=*

# ============================================
# 其他配置（可选）
# ============================================
# 时区设置
TIMEZONE=Asia/Shanghai

# 数据库路径
DB_PATH=data/leave_adjustments.db
