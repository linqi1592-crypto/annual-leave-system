# 飞书应用配置
# 请复制此文件为 .env 并填入真实值

FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_APP_TOKEN=your_app_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here

# CORS 允许的域名（生产环境必填，多个用逗号分隔）
# 示例：CORS_ORIGINS=https://applink.feishu.cn,https://your-domain.com
CORS_ORIGINS=*

# 时区设置
TIMEZONE=Asia/Shanghai
